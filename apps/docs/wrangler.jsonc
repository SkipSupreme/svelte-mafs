{
	"compatibility_date": "2026-04-24",
	"compatibility_flags": ["global_fetch_strictly_public", "nodejs_compat"],
	"name": "learntinker",
	"main": "@astrojs/cloudflare/entrypoints/server",
	"assets": {
		"directory": "./dist",
		"binding": "ASSETS"
	},
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "tinker",
			"database_id": "9ec67997-699d-48b5-a9d0-3ec23b2503bb",
			"migrations_dir": "./migrations"
		}
	],
	"observability": {
		"enabled": true
	},
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "tinker",
			"database_id": "REPLACE_WITH_REAL_ID_AFTER_WRANGLER_D1_CREATE",
			"migrations_dir": "migrations"
		}
	],
	"vars": {
		"PUBLIC_SITE_URL": "https://learntinker.com"
	},
	"routes": [
		{ "pattern": "learntinker.com", "custom_domain": true },
		{ "pattern": "www.learntinker.com", "custom_domain": true }
	]
}