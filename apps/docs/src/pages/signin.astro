---
export const prerender = false;
// Legacy route: /signin and /signup were collapsed into /auth?mode=...
// Preserve any query params the caller passed (error= from Better Auth
// callbacks, callbackURL=) so error banners and redirect targets survive.
const incoming = new URL(Astro.request.url).searchParams;
incoming.set('mode', 'signin');
return Astro.redirect(`/auth?${incoming.toString()}`, 302);
---
