---
import ThemeToggle from './ThemeToggle.astro';
import { createAuth } from '../server/auth';

let user: { name: string; email: string } | null = null;
try {
  const { env } = await import('cloudflare:workers');
  if (env?.DB) {
    const auth = createAuth(env);
    const session = await auth.api.getSession({ headers: Astro.request.headers });
    if (session) user = { name: session.user.name, email: session.user.email };
  }
} catch {
  user = null;
}
---

<header class="site-header">
  <div class="shell">
    <a href="/" class="brand" aria-label="Tinker home">
      <img src="/logo-mark.png" alt="" class="brand-mark" width="432" height="477" />
      <span class="wordmark">Tinker<em class="bang">!</em></span>
    </a>

    <div class="spacer"></div>

    <div class="counters" data-counters hidden>
      <span class="xp" aria-label="Experience points" data-xp>
        <span class="xp-bolt" aria-hidden="true">↑</span>
        <span class="xp-value" data-xp-value>0</span>
        <span class="xp-label" aria-hidden="true">XP</span>
      </span>
      <span class="streak" aria-label="Day streak" data-streak hidden>
        <span class="streak-num" data-streak-value>0</span>
        <span class="streak-flame" aria-hidden="true">🔥</span>
      </span>
    </div>

    <div class="auth-slot" data-auth-state={user ? 'user' : 'anon'}>
      <a
        href="/me"
        class="user-link"
        aria-label="Your account"
        data-auth-show="user"
        data-user-link
      >
        <span class="user-dot" aria-hidden="true" data-user-initial>
          {user ? (user.name || user.email).slice(0, 1).toUpperCase() : ''}
        </span>
        <span class="user-name" data-user-name>
          {user ? user.name || user.email.split('@')[0] : ''}
        </span>
      </a>
      <span class="auth-links" data-auth-show="anon">
        <a href="/signin" class="auth-link">Sign in</a>
        <a href="/signup" class="auth-cta">Sign up</a>
      </span>
    </div>

    <ThemeToggle />
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 10;
    background: color-mix(in srgb, var(--site-bg) 92%, transparent);
    backdrop-filter: saturate(180%) blur(8px);
    border-bottom: 1px solid var(--site-border);
  }
  .shell {
    max-width: var(--max-shell);
    margin: 0 auto;
    padding: 0.65rem 1.25rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    color: var(--site-fg);
    text-decoration: none;
  }
  .brand-mark {
    /* `/logo-mark.png` is the apple, cropped from the full lockup —
       no wordmark, no subtitle, no padding. So the nav can render it
       as a plain image with object-fit:contain and the whole apple is
       visible at any size. Aspect: 432, 477 ≈ 0.89:1 (slight portrait). */
    width: 44px;
    height: 44px;
    object-fit: contain;
    object-position: center;
    flex-shrink: 0;
  }
  .wordmark {
    font-family: var(--font-wordmark);
    font-weight: 800;
    font-size: 1.2rem;
    letter-spacing: -0.01em;
    line-height: 1;
  }
  .wordmark .bang {
    font-style: normal;
    color: var(--ink-red);
    margin-left: 0.05em;
  }
  .spacer { flex: 1; }

  .counters {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
  }
  .counters[hidden] { display: none; }
  .xp, .streak {
    display: inline-flex;
    align-items: center;
    gap: 0.2rem;
    padding: 0.28rem 0.6rem;
    border-radius: 999px;
    font-family: var(--font-game);
    font-variant-numeric: tabular-nums;
    font-size: 0.82rem;
    font-weight: 700;
    line-height: 1;
    white-space: nowrap;
  }
  .xp {
    background: color-mix(in srgb, var(--ink-red) 14%, transparent);
    color: var(--ink-red);
    position: relative;
    transition: transform 200ms cubic-bezier(0.2, 0.8, 0.2, 1);
  }
  .xp.xp-pulse {
    transform: scale(1.06);
  }
  .xp :global(.xp-floater-nav) {
    position: absolute;
    top: -0.4rem;
    right: 0.5rem;
    font-family: var(--font-game);
    font-weight: 800;
    font-size: 0.78rem;
    color: var(--cta-hover);
    pointer-events: none;
    will-change: transform, opacity;
  }
  .xp-bolt { font-size: 0.8rem; }
  .xp-label { opacity: 0.7; font-size: 0.72rem; letter-spacing: 0.08em; }
  .streak {
    background: color-mix(in srgb, var(--ink-sun) 18%, transparent);
    color: color-mix(in srgb, var(--ink-sun) 85%, var(--site-fg));
  }
  .streak[hidden] { display: none; }
  .streak-flame { font-size: 0.9rem; }

  .auth-slot {
    display: inline-flex;
    align-items: center;
  }
  .auth-slot[data-auth-state="user"] [data-auth-show="anon"] { display: none; }
  .auth-slot[data-auth-state="anon"] [data-auth-show="user"] { display: none; }
  .auth-links {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }
  .auth-link {
    color: var(--site-fg);
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 600;
    padding: 0.4rem 0.65rem;
    border-radius: 999px;
  }
  .auth-link:hover {
    background: var(--site-surface);
  }
  .auth-cta {
    color: var(--cta-fg);
    background: var(--cta);
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 650;
    padding: 0.4rem 0.85rem;
    border-radius: 999px;
    border: 1.5px solid var(--cta);
  }
  .auth-cta:hover {
    background: var(--cta-hover);
    border-color: var(--cta-hover);
  }
  .user-link {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    color: var(--site-fg);
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 600;
    padding: 0.3rem 0.6rem 0.3rem 0.3rem;
    border-radius: 999px;
    border: 1.5px solid var(--site-border);
  }
  .user-link:hover {
    background: var(--site-surface);
  }
  .user-dot {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.6rem;
    height: 1.6rem;
    border-radius: 999px;
    background: var(--ink-red);
    color: white;
    font-weight: 700;
    font-size: 0.78rem;
  }

  @media (max-width: 480px) {
    .xp-label { display: none; }
    .xp, .streak { padding: 0.22rem 0.5rem; font-size: 0.78rem; }
    .user-name, .auth-link { display: none; }
  }
</style>

<script>
  /**
   * Live XP + streak readout. Reads localStorage on load, then listens
   * for `tinker:xp` and `tinker:streak` events from lib/xp so the counter
   * updates the moment a learner earns the points.
   *
   * For returning users from before XP was first-class: if stored XP is 0
   * but lesson-progress keys exist, seed from step counts so they don't
   * see an empty counter.
   */
  const LS_XP = 'tinker:xp';
  const LS_STREAK = 'tinker:streak';

  function readInt(key: string, fallback = 0): number {
    const raw = localStorage.getItem(key);
    const n = raw == null ? NaN : parseInt(raw, 10);
    return Number.isFinite(n) ? n : fallback;
  }

  function seedXpFromLessonProgress(): number {
    let steps = 0;
    for (let i = 0; i < localStorage.length; i++) {
      const k = localStorage.key(i);
      if (k && k.startsWith('tinker:lesson:') && k.endsWith(':unlocked')) {
        steps += readInt(k, 0);
      }
    }
    return steps;
  }

  let xp = readInt(LS_XP);
  if (xp === 0) {
    const seeded = seedXpFromLessonProgress();
    if (seeded > 0) {
      xp = seeded;
      localStorage.setItem(LS_XP, String(xp));
    }
  }
  let streak = readInt(LS_STREAK);

  const counters = document.querySelector<HTMLElement>('[data-counters]');
  const xpEl = document.querySelector<HTMLElement>('[data-xp]');
  const xpVal = document.querySelector<HTMLElement>('[data-xp-value]');
  const streakEl = document.querySelector<HTMLElement>('[data-streak]');
  const streakVal = document.querySelector<HTMLElement>('[data-streak-value]');

  function paint() {
    if (!counters || !xpVal || !streakEl || !streakVal) return;
    if (xp > 0 || streak > 0) counters.hidden = false;
    xpVal.textContent = xp.toLocaleString();
    if (streak > 0) {
      streakEl.hidden = false;
      streakVal.textContent = String(streak);
    }
  }

  function flashGain(amount: number) {
    if (!xpEl || amount <= 0) return;
    if (matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    const float = document.createElement('span');
    float.className = 'xp-floater-nav';
    float.textContent = `+${amount}`;
    xpEl.appendChild(float);
    float.animate(
      [
        { transform: 'translateY(0)', opacity: 1 },
        { transform: 'translateY(-22px)', opacity: 0 },
      ],
      { duration: 720, easing: 'cubic-bezier(0.2, 0.8, 0.2, 1)', fill: 'forwards' },
    ).onfinish = () => float.remove();
    xpEl.classList.add('xp-pulse');
    setTimeout(() => xpEl.classList.remove('xp-pulse'), 320);
  }

  paint();

  window.addEventListener('tinker:xp', (e: Event) => {
    const detail = (e as CustomEvent<{ amount: number; total: number }>).detail;
    if (!detail) return;
    xp = detail.total;
    flashGain(detail.amount);
    paint();
  });

  window.addEventListener('tinker:streak', (e: Event) => {
    const detail = (e as CustomEvent<{ streak: number }>).detail;
    if (!detail) return;
    streak = detail.streak;
    paint();
  });

  /**
   * Auth hydration. Prerendered pages bake `data-auth-state="anon"` at build
   * time, so a logged-in visitor would otherwise see "Sign in / Sign up".
   * We fetch the session and flip the slot if there's a user. Skipped when
   * the server already rendered "user" (dynamic pages got it right).
   */
  type SessionResponse = { user?: { name?: string; email: string } };
  const slot = document.querySelector<HTMLElement>('.auth-slot');
  if (slot && slot.dataset.authState !== 'user') {
    fetch('/api/auth/get-session', { credentials: 'include' })
      .then((r) => (r.ok ? r.json() as Promise<SessionResponse> : null))
      .then((data) => {
        const user = data?.user;
        if (!user) return;
        const display = user.name || user.email.split('@')[0];
        const initial = (user.name || user.email).slice(0, 1).toUpperCase();
        slot.querySelector<HTMLElement>('[data-user-initial]')!.textContent = initial;
        slot.querySelector<HTMLElement>('[data-user-name]')!.textContent = display;
        slot.dataset.authState = 'user';
      })
      .catch(() => {
        /* network failure: leave anon state */
      });
  }
</script>
